# Nginx reverse-proxy rules for backend-driven deep linking.
# Include this inside the server { } block that serves the360ghar.com
# (and www./app. — either duplicate the server block per host or use a
# server_name covering all three).
#
# Origin backend:
set $deeplink_backend https://api.360ghar.com;

# --- Android / iOS verification files (served at the domain root) ---------
location = /.well-known/assetlinks.json {
    proxy_pass $deeplink_backend;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    # Do NOT add a trailing slash or rewrite the path.
}

location = /.well-known/apple-app-site-association {
    proxy_pass $deeplink_backend;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    # Apple requires application/json and no redirect — the backend sets this.
}

# --- Deep-link fallback pages (per app) -----------------------------------
# 360 Ghar (flagship, root paths)
location ~ ^/(p|property|tour)/ {
    proxy_pass $deeplink_backend;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}

# 360 Estate / FlatMates / Stays (namespaced)
location ~ ^/(estate|flatmates|stays)/ {
    proxy_pass $deeplink_backend;
    proxy_set_header Host $host;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
}

# Everything else on the360ghar.com falls through to your existing site config.
